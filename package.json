{
  "name": "discord-bot-wrapper",
  "version": "2.1.0",
  "description": "Discord Bot - Node.js Wrapper untuk menjalankan Python bot",
  "main": "bot.js",
  "type": "module",
  "scripts": {
    "start": "node bot.js",
    "dev": "node bot.js",
    "install-deps": "npm install && pip install -r requirements.txt",
